# Client environment
# In development, keep VITE_API_BASE_URL=/api so Vite proxies requests to
# http://localhost:10000 through client/vite.config.js.
# For a separate deployed static frontend, set this in Render to:
VITE_API_BASE_URL=https://your-backend-service.onrender.com/api

VITE_APP_TITLE=Project Repository
VITE_API_BASE_URL=/api
