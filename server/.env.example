NODE_ENV=development
PORT=10000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/project_archive

# JWT secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# Comma-separated admin emails (these users get admin role on registration)
ADMIN_EMAILS=admin@yourfaculty.edu.ng,hod@yourfaculty.edu.ng

# Resend API key (get from resend.com — optional in dev, emails print to console)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourprojectarchive.com

# Frontend URL (for email links and CORS)
CLIENT_ORIGIN=http://localhost:5173

# Upload temp directory
UPLOAD_DIR=uploads

# Max file size in bytes (default 20MB)
MAX_FILE_SIZE=20971520
