NODE_ENV=development
PORT=10000

# ── Database ─────────────────────────────────────────────────────────
# Set USE_LOCAL_DB=true to use a local JSON file (no PostgreSQL needed).
# Useful for testing on localhost. Data persists in server/local-data.json.
# To switch back to PostgreSQL: remove USE_LOCAL_DB and set DATABASE_URL.
USE_LOCAL_DB=true

# PostgreSQL connection string (only required when USE_LOCAL_DB is not set)
DATABASE_URL=postgresql://user:password@localhost:5432/project_archive

# JWT secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# Comma-separated admin emails (these users get admin role on registration)
ADMIN_EMAILS=admin@faculty.edu.ng,hod@faculty.edu.ng

# Resend API key (optional in dev, reset emails print to console)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourprojectarchive.com

# Frontend URL (for email links and CORS)
CLIENT_ORIGIN=http://localhost:5173

# Upload temp directory
UPLOAD_DIR=uploads

# Max file size in bytes (default 20MB)
MAX_FILE_SIZE=20971520
